# ============================================================
# VARIABILI D'AMBIENTE - da inserire su VERCEL (Settings -> Environment Variables)
# NON mettere qui i valori veri e NON committare questo file con le chiavi.
# Le chiavi le incolli solo nel pannello Vercel: io non le vedo mai.
# ============================================================

# --- Supabase (probabilmente le hai già impostate) ---
NEXT_PUBLIC_SUPABASE_URL=https://dwtxpbamjmlsfmwpyvgo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=la_tua_anon_key

# --- Supabase service-role (NUOVA, server-only) ---
# Supabase -> Project Settings -> API -> service_role secret
# ATTENZIONE: chiave potentissima, va SOLO su Vercel, mai nel browser.
SUPABASE_SERVICE_ROLE_KEY=la_tua_service_role_key

# --- Stripe ---
# Dashboard Stripe -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_...        # in test usa sk_test_, in produzione sk_live_

# Gli ID dei due prezzi creati in Stripe (Prodotti -> il tuo prodotto -> Prezzi)
STRIPE_PRICE_MENSILE=price_...       # il prezzo 3,99€/mese
STRIPE_PRICE_ANNUALE=price_...       # il prezzo 29€/anno

# Segreto del webhook (Developers -> Webhooks -> il tuo endpoint -> Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...
